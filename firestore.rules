rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidFileHistory(data) {
      return data.keys().hasAll(['uid', 'fileName', 'toolName', 'timestamp']) &&
             data.keys().size() == 4 &&
             data.uid is string && data.uid.size() >= 1 && data.uid.size() <= 128 &&
             data.fileName is string && data.fileName.size() >= 1 && data.fileName.size() <= 500 &&
             data.toolName is string && data.toolName.size() >= 1 && data.toolName.size() <= 100 &&
             data.uid == request.auth.uid;
    }

    match /fileHistory/{historyId} {
      // Allow reading user's own file history
      allow get: if isSignedIn() && isValidId(historyId) && existing().uid == request.auth.uid;
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;

      // Allow creating history records
      allow create: if isSignedIn() && isValidId(historyId) && isValidFileHistory(incoming());
      
      // History records are immutable, so no updates allowed
      allow update: if false;
      allow delete: if false;
    }
  }
}
