{
  "entities": {
    "FileHistory": {
      "title": "File History",
      "description": "A record of files processed by a user through various tools.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "User ID of the user who processed the file"
        },
        "fileName": {
          "type": "string",
          "description": "Name of the file processed"
        },
        "toolName": {
          "type": "string",
          "description": "Name of the tool used"
        },
        "timestamp": {
          "type": "object",
          "description": "Server timestamp of the operation"
        }
      },
      "required": ["uid", "fileName", "toolName", "timestamp"]
    }
  },
  "firestore": {
    "/fileHistory/{historyId}": {
      "schema": { "$ref": "FileHistory" },
      "description": "Storage for file processing history of users"
    }
  }
}
